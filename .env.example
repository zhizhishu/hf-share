# FusionSearch public ports
FUSIONSEARCH_PORT=1666
TZ=Asia/Shanghai

# Normal server mode
SEARCH_ENDPOINT=https://echocq-libresearch.hf.space/search
SEARCH_SH_CHAT_ENDPOINT=
SEARCH_SH_API_KEY=
RUNTIME_CONFIG_PATH=/app/config/runtime.json
LOG_DIR=/app/logs

# Official LibreSearch image tuning for all-in-one deployments
GRANIAN_PROCESS_NAME=fusionsearch-libre
GRANIAN_WORKERS=1
GRANIAN_BLOCKING_THREADS=4
UWSGI_WORKERS=1
UWSGI_THREADS=4

# Admin / MCP auth
ADMIN_AUTH_ENABLED=true
ADMIN_TOKEN=
SESSION_SECRET=
MCP_AUTH_TOKEN=

# Site access gate. When set, the homepage, search UI, /status and /admin are
# hidden behind a neutral cover page that asks for this access code. Leave empty
# to disable. MCP (Bearer) traffic and /health are never gated. Keep in Secrets.
SITE_GATE_PASSWORD=

# Hugging Face Space secret management from /admin.
# Use a fine-scoped write token. Keep this in Secrets only.
HF_ENDPOINT=https://huggingface.co
HF_SPACE_ID=
HF_WRITE_TOKEN=

# Optional persistence for ephemeral hosts (e.g. HF Spaces). When SUPABASE_URL
# and SUPABASE_SERVICE_KEY are set, the server restores config/runtime.json from
# a private Supabase Storage object on boot and mirrors every Admin save plus a
# periodic snapshot back to it, so runtime config survives a rebuild. Leave empty
# to disable (no-op). Use a server-side service_role / "secret" key; Secrets only.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_BUCKET=fusionsearch
SUPABASE_OBJECT=runtime.json
SUPABASE_BACKUP_INTERVAL_MS=300000

# Search-2api / search.sh
# Use the complete cookie header copied from the browser Network tab.
SEARCH_SH_COOKIE=
SEARCH_SH_USER_AGENT=
API_MASTER_KEY=

# Grok / OpenAI-compatible
GROK_API_URL=
GROK_API_KEY=
GROK_MODEL=grok-4.20-beta
GROK_SYSTEM_PROMPT=

# Tavily / Firecrawl
TAVILY_ENABLED=true
TAVILY_PROVIDER=
# Official REST base URL. Keep the default or point it at your own proxy.
TAVILY_API_URL=https://api.tavily.com
TAVILY_API_KEY=
# Third-party Tavily MCP/Hikari. If TAVILY_HIKARI_TOKEN is present and
# TAVILY_PROVIDER is unset, FusionSearch automatically uses provider=mcp.
TAVILY_MCP_URL=https://tavily.ivanli.cc/mcp
TAVILY_MCP_TOKEN=
TAVILY_HIKARI_TOKEN=
TAVILY_MCP_SEARCH_TOOL=
TAVILY_MCP_EXTRACT_TOOL=
TAVILY_MCP_MAP_TOOL=
FIRECRAWL_API_URL=https://api.firecrawl.dev/v2
FIRECRAWL_API_KEY=
