NODE_ENV=production
PORT=3000
ADMIN_PASSWORD=change-me

# Optional fallback values. The web UI can connect Claw with an email code
# and save these automatically in SQLite.
CLAW_API_KEY=
CLAW_DASHBOARD_COOKIE=
CLAW_WORKSPACE_ID=
CLAW_PARENT_MAILBOX_ID=
CLAW_ROOT_PREFIX=
CLAW_DOMAIN=claw.163.com

DATABASE_PATH=/app/data/app.db

# Optional second provider: self-hosted CF temp email (edu.002836.xyz).
# Leave blank to disable the "Temp Mail" group. Set the admin password as a
# platform secret, never commit the real value.
CF_TEMP_EMAIL_API_ENDPOINT=
CF_TEMP_EMAIL_DOMAIN=
CF_TEMP_EMAIL_ADMIN_PASSWORD=

# Optional persistence on ephemeral hosts (e.g. HuggingFace Spaces).
# When set, the server hydrates SQLite from Supabase on boot and mirrors
# every write back. Use a Supabase "secret" key (server-side, bypasses RLS).
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
